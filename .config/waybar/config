    ],
    "modules-right": [
        "mpd",
//      "idle_inhibitor",
        "pulseaudio",
//      "backlight",
        "keyboard-state",
        "battery#bat2",
        "hyprland/language",
        "network",
    	"clock",
	"custom/notification",
	"custom/power"
    ],
     // Language
    "hyprland/language": {
        "format": "{short}"
    },  
    // Disk
    "disk": {
        "interval": 10,
	"path": "/",
	"format": "{percentage_used}% ΎΓι",
	"tooltip-format": "{path}\nUsed: {used}\nFree: {free}\nTotal:  {total}",
	"states": {
	    "critical": 90
	}
    },
 
